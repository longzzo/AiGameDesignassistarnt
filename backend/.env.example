# ── 프로바이더 전환 ──────────────────────────────────────────────
# github = GitHub Models gpt-5 (배포/품질용, 토큰 필요)
# ollama = 로컬 Ollama (무료·무제한·오프라인 개발/테스트용, 토큰 불필요)
#   사전준비: Ollama 설치 후 `ollama pull qwen2.5:7b-instruct`
LLM_PROVIDER=github
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_ENDPOINT=http://localhost:11434/v1

# GitHub Models 연동 (LLM_PROVIDER=github 일 때 사용).
# GitHub > Settings > Developer settings > Personal access tokens 에서
# "models" 권한을 가진 토큰을 발급해 넣으세요.

GITHUB_MODELS_TOKEN=<your-github-pat-with-models-scope>

# 아래는 선택 (기본값이 들어가 있음)
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
LLM_MODEL_MAIN=openai/gpt-5         # 메인 두뇌: 프롬프트/시뮬 피드백/기획
LLM_MODEL_MINI=openai/gpt-5-mini    # 단순 반복/번역

# gpt-5 추론 강도. 낮을수록 빠르고 출력 토큰을 더 확보(minimal|low|medium|high).
# 기본 low 권장. 응답이 너무 느리거나 무료 티어 제한이 잦으면 minimal.
LLM_REASONING_EFFORT=low
